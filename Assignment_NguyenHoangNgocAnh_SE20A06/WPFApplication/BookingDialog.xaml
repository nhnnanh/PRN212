<Window x:Class="WPFApplication.BookingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Name="bookingDialogWindow"
        Title="{Binding Title}" 
        Height="500" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F8FAFC">

    <Window.Resources>
        <!-- Modern Cancel Button Style -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E2E8F0" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="20,0,20,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CBD5E1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Save Button Style -->
        <Style x:Key="SaveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6366F1" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="20,0,20,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4F46E5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="{Binding Title}" Foreground="#0F172A" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />

        <!-- Form fields -->
        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <!-- Customer -->
            <TextBlock Text="Customer" Foreground="#475569" FontSize="12" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding Customers}" 
                      SelectedValue="{Binding SelectedCustomerId}" 
                      SelectedValuePath="CustomerId" 
                      DisplayMemberPath="CustomerFullName"
                      Height="30" Margin="0,0,0,12" Background="#FFFFFF" Foreground="#0F172A" />

            <!-- Room -->
            <TextBlock Text="Room Information" Foreground="#475569" FontSize="12" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding Rooms}" 
                      SelectedValue="{Binding SelectedRoomId}" 
                      SelectedValuePath="RoomId" 
                      DisplayMemberPath="RoomNumber"
                      Height="30" Margin="0,0,0,12" Background="#FFFFFF" Foreground="#0F172A" />

            <!-- Booking Date -->
            <TextBlock Text="Booking Date" Foreground="#475569" FontSize="12" Margin="0,0,0,4" />
            <DatePicker SelectedDate="{Binding BookingDate}" Margin="0,0,0,12" Height="30" />

            <!-- Start Date -->
            <TextBlock Text="Start Date (Check-in)" Foreground="#475569" FontSize="12" Margin="0,0,0,4" />
            <DatePicker SelectedDate="{Binding StartDate}" Margin="0,0,0,12" Height="30" />

            <!-- End Date -->
            <TextBlock Text="End Date (Check-out)" Foreground="#475569" FontSize="12" Margin="0,0,0,4" />
            <DatePicker SelectedDate="{Binding EndDate}" Margin="0,0,0,12" Height="30" />

            <!-- Status -->
            <TextBlock Text="Booking Status" Foreground="#475569" FontSize="12" Margin="0,0,0,4" />
            <ComboBox SelectedIndex="{Binding StatusIndex}" Height="30" Margin="0,0,0,12" Background="#FFFFFF" Foreground="#0F172A">
                <ComboBoxItem Content="Active" />
                <ComboBoxItem Content="Canceled" />
            </ComboBox>

            <!-- Error message -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0" Height="24" />
        </StackPanel>

        <!-- Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource ModernButtonStyle}" Content="Cancel" Command="{Binding CancelCommand}" CommandParameter="{Binding ElementName=bookingDialogWindow}" MinWidth="90" Margin="0,0,10,0" />
            <Button Style="{StaticResource SaveButtonStyle}" Content="Save" Command="{Binding SaveCommand}" CommandParameter="{Binding ElementName=bookingDialogWindow}" MinWidth="90" />
        </StackPanel>
    </Grid>
</Window>
