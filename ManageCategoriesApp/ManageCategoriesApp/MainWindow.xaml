<Window x:Class="ManageCategoriesApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ManageCategoriesApp"
        mc:Ignorable="d"
        Title="Quản Lý Danh Mục Sản Phẩm" Height="600" Width="1000"
        Background="#F8FAFC" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Header Panel -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="20,16" Margin="0,0,0,20" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Decorative accent bar -->
                <Border Width="4" Height="32" Background="#3B82F6" CornerRadius="2" Margin="0,0,16,0"/>
                <StackPanel>
                    <TextBlock Text="HỆ THỐNG QUẢN LÝ DANH MỤC" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock Text="Kết nối Cơ sở dữ liệu thông qua EF Core và Repository Pattern" FontSize="12" Foreground="#64748B" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Input Form -->
                <ColumnDefinition Width="380"/>
                <!-- Gap -->
                <ColumnDefinition Width="20"/>
                <!-- Data List -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Form: Input Info -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Form Title -->
                    <TextBlock Grid.Row="0" Text="Thông tin danh mục" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,0,0,20"/>

                    <!-- Form Inputs -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Top">
                        <!-- ID -->
                        <TextBlock Text="Mã danh mục (ID)" FontSize="13" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox Name="txtCategoryID" IsReadOnly="True" Background="#F1F5F9" Foreground="#64748B" Margin="0,0,0,16" ToolTip="Mã số tự tăng của danh mục"/>

                        <!-- Name -->
                        <TextBlock Text="Tên danh mục" FontSize="13" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox Name="txtCategoryName" Margin="0,0,0,16" MaxLength="100"/>

                        <!-- Description -->
                        <TextBlock Text="Mô tả chi tiết" FontSize="13" FontWeight="SemiBold" Foreground="#475569" Margin="0,0,0,6"/>
                        <TextBox Name="txtDescription" Height="100" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top" Padding="10" Margin="0,0,0,20"/>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Add and Update -->
                        <Button Grid.Row="0" Grid.Column="0" Content="Thêm mới" Name="btnInsert" Style="{StaticResource ModernButton}" Click="btnInsert_Click" Margin="0,0,0,12"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="Cập nhật" Name="btnUpdate" Style="{StaticResource ModernButton}" Click="btnUpdate_Click" Margin="0,0,0,12"/>

                        <!-- Delete and Clear -->
                        <Button Grid.Row="1" Grid.Column="0" Content="Xóa bỏ" Name="btnDelete" Style="{StaticResource DangerButton}" Click="btnDelete_Click"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="Làm mới" Name="btnClear" Style="{StaticResource SecondaryButton}" Click="btnClear_Click"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Right: Data Grid & Table list -->
            <Border Grid.Column="2" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Danh sách danh mục hiện có" FontSize="16" FontWeight="SemiBold" Foreground="#1E293B" VerticalAlignment="Center"/>
                        <TextBlock Name="txtStatus" Text="Số lượng: 0" FontSize="13" Foreground="#64748B" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <DataGrid Grid.Row="1" Name="dgvCategories" SelectionChanged="dgvCategories_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Mã ID" Binding="{Binding Id}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Tên danh mục" Binding="{Binding CategoryName}" Width="200" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Mô tả chi tiết" Binding="{Binding Description}" Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Footer instruction -->
                    <Border Grid.Row="2" Background="#EFF6FF" CornerRadius="6" Padding="12" Margin="0,16,0,0">
                        <TextBlock Text="* Hướng dẫn: Chọn một hàng trên bảng để chỉnh sửa thông tin hoặc xóa. Nhấn 'Làm mới' để xóa biểu mẫu nhập." FontSize="12" Foreground="#1E40AF" HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
