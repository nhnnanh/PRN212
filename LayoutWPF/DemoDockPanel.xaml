<Window x:Class="LayoutWPF.DemoDockPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Demo Dock Panel" Height="300" Width="400"
        WindowStartupLocation="CenterScreen">
    <DockPanel Background="LightBlue" LastChildFill="True">
        <!-- Button 1: Docked to Top with Height="50" -->
        <Button Content="Top" DockPanel.Dock="Top" Height="50" Margin="2" Click="Button_Click" Background="#E74C3C" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0"/>
        
        <!-- Button 2: Docked to Bottom with Height="50" -->
        <Button Content="Bottom" DockPanel.Dock="Bottom" Height="50" Margin="2" Click="Button_Click" Background="#2ECC71" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0"/>
        
        <!-- Button 3: Docked to Left with Width="50" -->
        <Button Content="Left" DockPanel.Dock="Left" Width="50" Margin="2" Click="Button_Click" Background="#F1C40F" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0"/>
        
        <!-- Button 4: Docked to Right with Width="50" -->
        <Button Content="Right" DockPanel.Dock="Right" Width="50" Margin="2" Click="Button_Click" Background="#9B59B6" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0"/>
        
        <!-- Button 5: Center (will automatically fill the remaining area) -->
        <Button Content="Center" Margin="2" Click="Button_Click" Background="#34495E" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0"/>
    </DockPanel>
</Window>
