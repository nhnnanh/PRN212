<Window x:Class="WPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFApp"
        mc:Ignorable="d"
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterScreen"
        Title="Product Store Management" Height="680" Width="800"
        Background="#F3F2F1">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title -->
            <RowDefinition Height="Auto"/> <!-- Form Fields -->
            <RowDefinition Height="*"/>    <!-- Data Grid -->
            <RowDefinition Height="Auto"/> <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="PRODUCT MANAGEMENT" FontSize="24" FontWeight="Bold" Foreground="#0078D4" Margin="0,0,0,15" HorizontalAlignment="Center"/>

        <!-- Form fields inside a nice Border Card -->
        <Border Grid.Row="1" Background="White" BorderBrush="#EDEBE9" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 1 -->
                <Label Grid.Row="0" Grid.Column="0" Content="Product ID" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox x:Name="txtProductID" Grid.Row="0" Grid.Column="1" Height="28" IsEnabled="False" VerticalContentAlignment="Center" Background="#F3F2F1"/>

                <Label Grid.Row="0" Grid.Column="3" Content="Product Name" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox x:Name="txtProductName" Grid.Row="0" Grid.Column="4" Height="28" VerticalContentAlignment="Center"/>

                <!-- Row 2 -->
                <Label Grid.Row="2" Grid.Column="0" Content="Price" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox x:Name="txtPrice" Grid.Row="2" Grid.Column="1" Height="28" VerticalContentAlignment="Center"/>

                <Label Grid.Row="2" Grid.Column="3" Content="Units In Stock" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox x:Name="txtUnitsInStock" Grid.Row="2" Grid.Column="4" Height="28" VerticalContentAlignment="Center"/>

                <!-- Row 3 -->
                <Label Grid.Row="4" Grid.Column="0" Content="Category" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <ComboBox x:Name="cboCategory" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4" Height="28" VerticalContentAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="2" Background="White" BorderBrush="#EDEBE9" BorderThickness="1" CornerRadius="4" Padding="5" Margin="0,0,0,15">
            <DataGrid x:Name="dgData" BorderThickness="0" Background="White" AutoGenerateColumns="False" 
                      SelectionChanged="dgData_SelectionChanged" IsReadOnly="True" AlternatingRowBackground="#FAF9F8" RowHeaderWidth="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId}" Width="100"/>
                    <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="*"/>
                    <DataGridTextColumn Header="Category" Binding="{Binding Category.CategoryName}" Width="150"/>
                    <DataGridTextColumn Header="Units In Stock" Binding="{Binding UnitsInStock}" Width="120"/>
                    <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat={}{0:N0}}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="btnCreate" Grid.Column="0" Content="Create" Width="100" Height="32" Background="#107C41" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="btnCreate_Click"/>
            <Button x:Name="btnUpdate" Grid.Column="2" Content="Update" Width="100" Height="32" Background="#0078D4" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="btnUpdate_Click"/>
            <Button x:Name="btnDelete" Grid.Column="4" Content="Delete" Width="100" Height="32" Background="#A80000" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="btnDelete_Click"/>
            <Button x:Name="btnClose" Grid.Column="6" Content="Close" Width="100" Height="32" Background="#7A7A7A" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="btnClose_Click"/>
        </Grid>
    </Grid>
</Window>
