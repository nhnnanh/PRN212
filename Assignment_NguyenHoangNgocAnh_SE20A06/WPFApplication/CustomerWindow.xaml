<Window x:Class="WPFApplication.CustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Name="custWindow"
        Title="FUMiniHotel System - Customer Dashboard" 
        Height="550" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">

    <Window.Resources>
        <!-- Modern Rounded Button Style -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E2E8F0" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="20,0,20,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CBD5E1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#6366F1" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <!-- TabControl Styling -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <ContentPresenter Content="{TemplateBinding Content}" Margin="10,6" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" BorderThickness="0,0,0,2" BorderBrush="Transparent" Padding="5">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                               ContentSource="Header" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#6366F1" />
                                <Setter Property="Foreground" Value="#4F46E5" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#1E293B" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Rounded TextBox Style -->
        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6,8,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="#0F172A" />
            <Setter Property="SelectionBrush" Value="#6366F1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1" />
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#F1F5F9" />
                                <Setter Property="Foreground" Value="#94A3B8" />
                                <Setter TargetName="border" Property="BorderBrush" Value="#E2E8F0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Dark DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="RowBackground" Value="#FFFFFF" />
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="SelectionMode" Value="Single" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F5F9" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8,10,8" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,8,10,8" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4F46E5" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Header Panel -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0" Padding="20,12,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="FUMiniHotel" Foreground="#6366F1" FontSize="20" FontWeight="Black" />
                    <TextBlock Text="CUSTOMER DASHBOARD" Foreground="#64748B" FontSize="11" FontWeight="Bold" VerticalAlignment="Bottom" Margin="10,0,0,2" />
                </StackPanel>

                <Button Grid.Column="1" Style="{StaticResource ModernButtonStyle}" Content="Logout" 
                        Command="{Binding LogoutCommand}" 
                        CommandParameter="{Binding ElementName=custWindow}" />
            </Grid>
        </Border>

        <!-- Main Body Tab Control -->
        <TabControl Grid.Row="1" Margin="16">
            <!-- TAB 1: PROFILE & HISTORY -->
            <TabItem Header="My Profile &amp; History">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Profile Info Form (Left Column) -->
                    <Border Grid.Column="0" Background="#FFFFFF" BorderThickness="1" BorderBrush="#E2E8F0" CornerRadius="8" Padding="20" Margin="0,0,20,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="My Profile" Foreground="#0F172A" FontSize="16" FontWeight="Bold" Margin="0,0,0,16" />

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel VerticalAlignment="Top">
                                    <TextBlock Text="Full Name" Foreground="#475569" FontSize="12" Margin="0,0,0,4" />
                                    <TextBox Style="{StaticResource ModernTextBoxStyle}" Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                                    <TextBlock Text="Telephone" Foreground="#475569" FontSize="12" Margin="0,0,0,4" />
                                    <TextBox Style="{StaticResource ModernTextBoxStyle}" Text="{Binding Telephone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                                    <TextBlock Text="Email Address" Foreground="#475569" FontSize="12" Margin="0,0,0,4" />
                                    <TextBox Style="{StaticResource ModernTextBoxStyle}" Text="{Binding Email}" IsEnabled="False" Margin="0,0,0,12" />

                                    <TextBlock Text="Birthday" Foreground="#475569" FontSize="12" Margin="0,0,0,4" />
                                    <DatePicker SelectedDate="{Binding Birthday}" Margin="0,0,0,12" Height="30" />

                                    <TextBlock Text="Password" Foreground="#475569" FontSize="12" Margin="0,0,0,4" />
                                    <TextBox Style="{StaticResource ModernTextBoxStyle}" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" />

                                    <!-- Feedback Messages -->
                                    <TextBlock Text="{Binding SuccessMessage}" Foreground="#059669" FontSize="12" TextWrapping="Wrap" FontWeight="SemiBold" TextAlignment="Center" />
                                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" FontSize="12" TextWrapping="Wrap" FontWeight="SemiBold" TextAlignment="Center" />
                                </StackPanel>
                            </ScrollViewer>

                            <Button Grid.Row="2" Style="{StaticResource PrimaryButtonStyle}" Content="Update Profile" Command="{Binding UpdateProfileCommand}" Margin="0,16,0,0" />
                        </Grid>
                    </Border>

                    <!-- Booking History (Right Column) -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="My Booking History" Foreground="#0F172A" FontSize="16" FontWeight="Bold" Margin="0,0,0,16" />

                        <DataGrid Grid.Row="1" ItemsSource="{Binding BookingHistory}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Reservation ID" Binding="{Binding BookingReservationId}" Width="120" />
                                <DataGridTextColumn Header="Booking Date" Binding="{Binding BookingDate, StringFormat=yyyy-MM-dd}" Width="150" />
                                <DataGridTextColumn Header="Total Price" Binding="{Binding TotalPrice, StringFormat={}{0:C}}" Width="150" />
                                <DataGridTextColumn Header="Status" Binding="{Binding BookingStatus}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TAB 2: ONLINE BOOKING -->
            <TabItem Header="Book a Room">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: Available Rooms Grid & Search -->
                    <Grid Grid.Column="0" Margin="0,0,20,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Search -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Select a Room to Book" Foreground="#0F172A" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <TextBlock Text="Search Room No:" Foreground="#475569" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox Width="180" Height="30" Style="{StaticResource ModernTextBoxStyle}" 
                                         Text="{Binding SearchRoomText, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <!-- Data Grid -->
                        <DataGrid Grid.Row="1" ItemsSource="{Binding AvailableRooms}" SelectedItem="{Binding SelectedRoom}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Room Number" Binding="{Binding RoomNumber}" Width="120" />
                                <DataGridTextColumn Header="Capacity" Binding="{Binding RoomMaxCapacity}" Width="90" />
                                <DataGridTextColumn Header="Price per Day" Binding="{Binding RoomPricePerDay, StringFormat={}{0:C}}" Width="140" />
                                <DataGridTextColumn Header="Type" Binding="{Binding RoomType.RoomTypeName}" Width="180" />
                                <DataGridTextColumn Header="Description" Binding="{Binding RoomDetailDescription}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>

                    <!-- Right: Booking Form -->
                    <Border Grid.Column="1" Background="#FFFFFF" BorderThickness="1" BorderBrush="#E2E8F0" CornerRadius="8" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Reservation Details" Foreground="#0F172A" FontSize="16" FontWeight="Bold" Margin="0,0,0,16" />

                            <StackPanel Grid.Row="1" VerticalAlignment="Top">
                                <TextBlock Text="Selected Room" Foreground="#475569" FontSize="12" Margin="0,0,0,4" />
                                <TextBox Style="{StaticResource ModernTextBoxStyle}" Text="{Binding SelectedRoom.RoomNumber}" IsEnabled="False" Margin="0,0,0,12" />

                                <TextBlock Text="Check-in Date" Foreground="#475569" FontSize="12" Margin="0,0,0,4" />
                                <DatePicker SelectedDate="{Binding BookingStartDate}" Margin="0,0,0,12" Height="30" />

                                <TextBlock Text="Check-out Date" Foreground="#475569" FontSize="12" Margin="0,0,0,16" />
                                <DatePicker SelectedDate="{Binding BookingEndDate}" Margin="0,0,0,16" Height="30" />

                                <!-- Feedbacks -->
                                <TextBlock Text="{Binding BookingFeedback}" Foreground="#059669" FontSize="12" TextWrapping="Wrap" FontWeight="SemiBold" TextAlignment="Center" />
                                <TextBlock Text="{Binding BookingError}" Foreground="#DC2626" FontSize="12" TextWrapping="Wrap" FontWeight="SemiBold" TextAlignment="Center" />
                            </StackPanel>

                            <Button Grid.Row="2" Style="{StaticResource PrimaryButtonStyle}" Content="Book Room Now" Command="{Binding BookRoomCommand}" Margin="0,16,0,0" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
