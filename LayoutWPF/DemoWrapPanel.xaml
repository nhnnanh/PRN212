<Window x:Class="LayoutWPF.DemoWrapPanel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Demo Wrap Panel" Height="400" Width="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Border Background="LightBlue" Padding="15">
        <WrapPanel Orientation="Vertical">
            <Label Content="Enter Car Information" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>
            
            <Label Content="Car Name:" FontSize="12" Foreground="#2C3E50" Margin="0,0,0,2"/>
            <TextBox x:Name="txtCarName" Width="250" Height="26" VerticalContentAlignment="Center" Padding="4,0,0,0" Margin="0,0,0,10"/>
            
            <Label Content="Color:" FontSize="12" Foreground="#2C3E50" Margin="0,0,0,2"/>
            <TextBox x:Name="txtColor" Width="250" Height="26" VerticalContentAlignment="Center" Padding="4,0,0,0" Margin="0,0,0,10"/>
            
            <Label Content="Brand:" FontSize="12" Foreground="#2C3E50" Margin="0,0,0,2"/>
            <TextBox x:Name="txtBrand" Width="250" Height="26" VerticalContentAlignment="Center" Padding="4,0,0,0" Margin="0,0,0,15"/>
            
            <Button x:Name="btnDisplay" Content="Display" Width="100" Height="35" Click="btnDisplay_Click" Background="#2980B9" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
        </WrapPanel>
    </Border>
</Window>
