<Window x:Class="LayoutWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WPF Layout Panels Explorer" Height="500" Width="800"
        WindowStartupLocation="CenterScreen" Background="#1E202B" ResizeMode="CanMinimize">
    
    <Window.Resources>
        <!-- Modern Card Style Button -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2980B9"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3498DB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#21618C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Panel with Gradient -->
        <Border Grid.Row="0" BorderBrush="#2D303E" BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#161822" Offset="0"/>
                    <GradientStop Color="#2C3E50" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="30,0,0,0">
                <TextBlock Text="WPF PANEL LAYOUT EXPLORER" FontSize="22" FontWeight="Bold" Foreground="#ECF0F1"/>
                <TextBlock Text="A complete tutorial application showcasing the behavior of major WPF layout containers." FontSize="12" Foreground="#BDC3C7" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Cards Hub -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                
                <!-- Canvas Card -->
                <Border Width="220" Height="160" Margin="10" CornerRadius="8" Background="#262A3B" BorderBrush="#353A52" BorderThickness="1" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="1. Canvas Panel" FontSize="15" FontWeight="Bold" Foreground="#E74C3C"/>
                        <TextBlock Grid.Row="1" Text="Absolute coordinates. Best for custom graphics/drawing." TextWrapping="Wrap" FontSize="11" Foreground="#BDC3C7" Margin="0,8,0,5"/>
                        <Button Grid.Row="2" Content="Open Canvas Demo" Height="30" Click="OpenCanvas_Click"/>
                    </Grid>
                </Border>

                <!-- WrapPanel Card -->
                <Border Width="220" Height="160" Margin="10" CornerRadius="8" Background="#262A3B" BorderBrush="#353A52" BorderThickness="1" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="2. WrapPanel" FontSize="15" FontWeight="Bold" Foreground="#3498DB"/>
                        <TextBlock Grid.Row="1" Text="Sequential horizontal or vertical flow with auto wrapping." TextWrapping="Wrap" FontSize="11" Foreground="#BDC3C7" Margin="0,8,0,5"/>
                        <Button Grid.Row="2" Content="Open Wrap Demo" Height="30" Click="OpenWrap_Click"/>
                    </Grid>
                </Border>

                <!-- StackPanel Card -->
                <Border Width="220" Height="160" Margin="10" CornerRadius="8" Background="#262A3B" BorderBrush="#353A52" BorderThickness="1" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="3. StackPanel" FontSize="15" FontWeight="Bold" Foreground="#2ECC71"/>
                        <TextBlock Grid.Row="1" Text="Vertical/Horizontal single-line stack. Ideal for simple forms." TextWrapping="Wrap" FontSize="11" Foreground="#BDC3C7" Margin="0,8,0,5"/>
                        <Button Grid.Row="2" Content="Open Stack Demo" Height="30" Click="OpenStack_Click"/>
                    </Grid>
                </Border>

                <!-- Grid Card -->
                <Border Width="220" Height="160" Margin="10" CornerRadius="8" Background="#262A3B" BorderBrush="#353A52" BorderThickness="1" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="4. Grid Panel" FontSize="15" FontWeight="Bold" Foreground="#F1C40F"/>
                        <TextBlock Grid.Row="1" Text="Column &amp; Row structure. Perfect for standard window layouts." TextWrapping="Wrap" FontSize="11" Foreground="#BDC3C7" Margin="0,8,0,5"/>
                        <Button Grid.Row="2" Content="Open Grid Demo" Height="30" Click="OpenGrid_Click"/>
                    </Grid>
                </Border>

                <!-- DockPanel Card -->
                <Border Width="220" Height="160" Margin="10" CornerRadius="8" Background="#262A3B" BorderBrush="#353A52" BorderThickness="1" Padding="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="5. DockPanel" FontSize="15" FontWeight="Bold" Foreground="#9B59B6"/>
                        <TextBlock Grid.Row="1" Text="Anchor to borders (Top, Bottom, Left, Right). Center fills remaining." TextWrapping="Wrap" FontSize="11" Foreground="#BDC3C7" Margin="0,8,0,5"/>
                        <Button Grid.Row="2" Content="Open Dock Demo" Height="30" Click="OpenDock_Click"/>
                    </Grid>
                </Border>

            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Window>
