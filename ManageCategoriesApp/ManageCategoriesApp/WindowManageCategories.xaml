<Window x:Class="ManageCategoriesApp.WindowManageCategories"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ManageCategoriesApp"
        mc:Ignorable="d"
        Title="Manage Categories" Height="430" Width="420"
        Loaded="Window_Loaded" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    
    <DockPanel VerticalAlignment="Top" Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Form Information -->
            <Border Grid.Row="0" Background="LightBlue" Padding="15">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Category Information" Foreground="Red" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <Label Content="CategoryID" Padding="0,5"/>
                    <TextBox Name="txtCategoryID" IsReadOnly="True" Height="25" Margin="0,0,0,10" Padding="5,2" VerticalContentAlignment="Center"
                             DataContext="{Binding ElementName=lvCategories, Path=SelectedItem}"
                             Text="{Binding Path=CategoryID, Mode=OneWay}"/>
                    
                    <Label Content="Category Name" Padding="0,5"/>
                    <TextBox Name="txtCategoryName" Height="25" Margin="0,0,0,15" Padding="5,2" VerticalContentAlignment="Center"
                             DataContext="{Binding ElementName=lvCategories, Path=SelectedItem}"
                             Text="{Binding Path=CategoryName, Mode=OneWay}"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,5">
                        <Button Name="btnInsert" Content="Insert" Width="75" Height="25" Margin="5,0" Click="btnInsert_Click"/>
                        <Button Name="btnUpdate" Content="Update" Width="75" Height="25" Margin="5,0" Click="btnUpdate_Click"/>
                        <Button Name="btnDelete" Content="Delete" Width="75" Height="25" Margin="5,0" Click="btnDelete_Click"/>
                        <Button Name="btnReset" Content="Reset" Width="75" Height="25" Margin="5,0" Click="btnReset_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Row 1: List View -->
            <ListView Grid.Row="1" Name="lvCategories" Height="165" Margin="0,10,0,0" VerticalAlignment="Top">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Category ID" DisplayMemberBinding="{Binding CategoryID}" Width="100"/>
                        <GridViewColumn Header="Category Name" DisplayMemberBinding="{Binding CategoryName}" Width="260"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </DockPanel>
</Window>
